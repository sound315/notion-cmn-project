# Notion Integration 시크릿 키
# https://www.notion.so/my-integrations 에서 발급
NOTION_API_KEY=your_notion_integration_secret

# Notion 데이터베이스 ID (Invoices)
# 데이터베이스 URL에서 추출: https://www.notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=your_database_id

# Notion 데이터베이스 ID (Items)
NOTION_ITEMS_DATABASE_ID=your_items_database_id

# 관리자 비밀번호 (Phase 7)
ADMIN_PASSWORD=your_admin_password
